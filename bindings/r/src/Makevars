# The wickra-verify C ABI header and library are provided out-of-tree via the
# WKVERIFY_INC (include dir) and WKVERIFY_LIB (library dir) environment variables,
# set by CI / the installer. The Makevars do not bake an rpath; the loader must
# find the shared library via LD_LIBRARY_PATH / DYLD_LIBRARY_PATH at run time.
PKG_CPPFLAGS = -I$(WKVERIFY_INC)
PKG_LIBS = -L$(WKVERIFY_LIB) -lwickra_verify
